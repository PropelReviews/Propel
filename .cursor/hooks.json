{
  "$schema": "https://unpkg.com/cursor-hooks@latest/schema/hooks.schema.json",
  "version": 1,
  "hooks": {
    "postToolUse": [
      {
        "command": ".cursor/hooks/check-format.sh",
        "matcher": "Write|StrReplace|EditNotebook",
        "timeout": 30
      },
      {
        "command": ".cursor/hooks/check-ruff.sh",
        "matcher": "Write|StrReplace|EditNotebook",
        "timeout": 30
      }
    ],
    "stop": [
      {
        "command": ".cursor/hooks/stop-verify.sh",
        "timeout": 600,
        "loop_limit": 8
      }
    ]
  }
}
