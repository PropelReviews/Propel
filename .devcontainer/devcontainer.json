{
  "name": "Propel",
  "dockerComposeFile": "../docker-compose.yml",
  "service": "dev",
  "runServices": ["postgres", "backend", "frontend"],
  "workspaceFolder": "/workspaces/Propel",
  "remoteUser": "vscode",
  "shutdownAction": "stopCompose",
  "forwardPorts": [8000, 5173, 5432],
  "portsAttributes": {
    "8000": {
      "label": "Backend",
      "onAutoForward": "notify"
    },
    "5173": {
      "label": "Frontend (Vite)",
      "onAutoForward": "notify"
    },
    "5432": {
      "label": "Postgres",
      "onAutoForward": "silent"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "ms-azuretools.vscode-docker"
      ]
    }
  }
}
