# Zitadel defaults for local docker compose. Override in .env if needed.
ZITADEL_VERSION=v2.71.10
ZITADEL_MASTERKEY=MasterkeyNeedsToHave32Characters
ZITADEL_DOMAIN=localhost
ZITADEL_EXTERNALPORT=8080
ZITADEL_EXTERNALSECURE=false
ZITADEL_PUBLIC_SCHEME=http
ZITADEL_DATABASE_POSTGRES_DSN=postgresql://propel:propel@postgres:5432/zitadel?sslmode=disable
LOGIN_CLIENT_PAT_EXPIRATION=2099-01-01T00:00:00Z
