# =============================================================================
# Propel — environment configuration
# Copy this file to .env and adjust values for your local setup.
# =============================================================================

# Postgres
POSTGRES_USER=propel
POSTGRES_PASSWORD=propel
POSTGRES_DB=propel
POSTGRES_PORT=5432

# Backend (FastAPI)
BACKEND_PORT=8000
DATABASE_URL=postgresql://propel:propel@localhost:5432/propel

# Frontend (Vite)
FRONTEND_PORT=5173

# -----------------------------------------------------------------------------
# Integrations (optional — required when running Meltano extractors)
# -----------------------------------------------------------------------------

# GitHub
# GITHUB_TOKEN=

# Linear
# LINEAR_API_KEY=

# Cursor
# CURSOR_API_KEY=
