# =============================================================================
# Propel — environment configuration
# Copy this file to .env and adjust values for your local setup.
# =============================================================================

# Postgres
POSTGRES_USER=propel
POSTGRES_PASSWORD=propel
POSTGRES_DB=propel
POSTGRES_PORT=5432

# Backend (FastAPI)
BACKEND_PORT=8000
DATABASE_URL=postgresql://propel:propel@localhost:5432/propel

# Frontend (Vite)
FRONTEND_PORT=5173

# -----------------------------------------------------------------------------
# Analytics (optional — PostHog product analytics)
# -----------------------------------------------------------------------------

# Write-only project token; safe for client-side use
# POSTHOG_API_KEY=
# POSTHOG_HOST=https://us.i.posthog.com
# POSTHOG_PROJECT_ID=245238

# Frontend reads VITE_POSTHOG_KEY (docker-compose maps from POSTHOG_API_KEY)
# VITE_POSTHOG_KEY=
# VITE_POSTHOG_HOST=https://us.i.posthog.com

# Backend OpenTelemetry distributed tracing -> PostHog (uses POSTHOG_API_KEY).
# Tracing is disabled automatically when POSTHOG_API_KEY is unset.
# OTEL_SERVICE_NAME=propel-backend

# -----------------------------------------------------------------------------
# Integrations (optional — required when running Meltano extractors)
# -----------------------------------------------------------------------------

# GitHub
# GITHUB_TOKEN=

# Linear
# LINEAR_API_KEY=

# Cursor
# CURSOR_API_KEY=
