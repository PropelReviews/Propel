# =============================================================================
# Propel — environment configuration
# Copy this file to .env and adjust values for your local setup.
# =============================================================================

# Postgres
POSTGRES_USER=propel
POSTGRES_PASSWORD=propel
POSTGRES_DB=propel
POSTGRES_PORT=5432

# Backend (FastAPI)
BACKEND_PORT=8000
DATABASE_URL=postgresql://propel:propel@localhost:5432/propel

# Frontend (Vite)
FRONTEND_PORT=5173

# Base URL the SPA calls for the API. Defaults to the local backend; the AWS
# deploy script sets this per environment (e.g. https://api.beta.propel.ninja).
# VITE_API_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# Analytics (optional — PostHog product analytics)
# -----------------------------------------------------------------------------

# Write-only project token; safe for client-side use
# POSTHOG_TOKEN=
# POSTHOG_HOST=https://us.i.posthog.com
# POSTHOG_PROJECT_ID=245238

# Frontend reads VITE_POSTHOG_KEY (docker-compose maps from POSTHOG_TOKEN)
# VITE_POSTHOG_KEY=
# VITE_POSTHOG_HOST=https://us.i.posthog.com

# Backend OpenTelemetry distributed tracing -> PostHog (uses POSTHOG_TOKEN).
# Tracing is disabled automatically when POSTHOG_TOKEN is unset.
# OTEL_SERVICE_NAME=propel-backend

# -----------------------------------------------------------------------------
# Integrations (optional — required when running Meltano extractors)
# -----------------------------------------------------------------------------

# GitHub
# GITHUB_TOKEN=

# Linear
# LINEAR_API_KEY=

# Cursor
# CURSOR_API_KEY=

# -----------------------------------------------------------------------------
# AWS deployment (Terraform + GitHub Actions)
# -----------------------------------------------------------------------------
# These values are NOT read from this file in AWS. App config is generic: every
# GitHub Actions variable is forwarded by CI into both the API container env
# (Terraform app_environment) and the SPA build env. Adding a key is just adding
# an Actions variable -- no code changes. Examples:
#   - POSTHOG_TOKEN / POSTHOG_HOST -> API (OTEL -> PostHog) + SPA build
#   - VITE_API_URL                   -> SPA build (set per environment)
# Truly sensitive values use Terraform app_secrets (Secrets Manager) instead.
# See infrastructure/terraform/README.md for the full deploy runbook.
