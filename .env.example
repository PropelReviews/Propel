# =============================================================================
# Propel — environment configuration
# Copy this file to .env and adjust values for your local setup.
# =============================================================================

# Postgres
POSTGRES_USER=propel
POSTGRES_PASSWORD=propel
POSTGRES_DB=propel
POSTGRES_PORT=5432

# Backend (FastAPI)
BACKEND_PORT=8000
DATABASE_URL=postgresql://propel:propel@localhost:5432/propel

# Auth (JWT + OAuth login)
JWT_SECRET=change-me
JWT_LIFETIME_SECONDS=3600
# Set to "true" to allow POST /api/v1/auth/register (off by default).
AUTH_REGISTRATION_ENABLED=true
# Per-IP limits on POST /api/v1/auth/login and /register.
AUTH_RATE_LIMIT_MAX_REQUESTS=10
AUTH_RATE_LIMIT_WINDOW_SECONDS=60
# App environment — production/beta require a strong JWT_SECRET (>= 32 chars).
APP_ENV=development
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=
# Base URL of the API — where GitHub/Google send the OAuth callback (the backend).
OAUTH_CALLBACK_BASE_URL=http://localhost:8000
# Base URL of the browser SPA. OAuth callbacks finish by redirecting the browser
# here (e.g. sign-in lands on {FRONTEND_BASE_URL}/auth/github/callback). In AWS
# the SPA is a separate origin from the API, so set this to https://app.<zone>.
FRONTEND_BASE_URL=http://localhost:5173

# Comma-separated browser origins allowed to call the API (CORS). The SPA dev
# server runs on :5173. In AWS, Terraform injects https://app.<zone> automatically;
# only set this in GitHub Actions if you need additional origins.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Frontend (Vite)
FRONTEND_PORT=5173
# Marketing landing site dev server (separate Vite app, served at apex/www in prod)
FRONTEND_LANDING_PORT=5174

# Static landing page preview (docker compose --profile landing up frontend-landing-static)
LANDING_PORT=8080

# Base URL the SPA calls for the API. Defaults to the local backend; the AWS
# deploy script sets this per environment (e.g. https://api.beta.propel.ninja).
# VITE_API_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# Analytics (optional — PostHog product analytics)
# -----------------------------------------------------------------------------

# Write-only project token; safe for client-side use
# POSTHOG_TOKEN=
# POSTHOG_HOST=https://us.i.posthog.com
# POSTHOG_PROJECT_ID=245238

# Personal API key with error-tracking write access — used at build time only
# to upload frontend source maps (never ship this to the browser).
# POSTHOG_PERSONAL_API_KEY=phx_...

# Frontend reads VITE_POSTHOG_KEY (docker-compose maps from POSTHOG_TOKEN)
# VITE_POSTHOG_KEY=
# VITE_POSTHOG_HOST=https://us.i.posthog.com

# Sign up / sign in is gated behind the PostHog feature flag `signup-signin`.
# When PostHog is disabled (no key), set this to "true" to show auth anyway.
# VITE_AUTH_ENABLED=false

# Optional build-time metadata, registered as PostHog super properties on every
# event. Defaults: VITE_APP_ENV -> Vite mode, VITE_APP_VERSION -> package.json
# version, VITE_GIT_SHA -> "dev". The deploy script sets ENV + git SHA per build.
# VITE_APP_ENV=
# VITE_APP_VERSION=
# VITE_GIT_SHA=

# Backend OpenTelemetry -> PostHog (uses POSTHOG_TOKEN). Tracing and log export
# are disabled automatically when POSTHOG_TOKEN is unset.
# OTEL_SERVICE_NAME=propel-backend

# -----------------------------------------------------------------------------
# Ingestion — GitHub App (data extraction, separate from login OAuth above)
# -----------------------------------------------------------------------------
# The GitHub App installed per tenant. Its private key signs the app JWT that is
# exchanged for per-installation tokens; the webhook secret verifies install
# events. Needs "Organization Copilot metrics: Read" for Copilot usage.
#
# Recommended: don't hand-edit these. The shared DEV GitHub App lives in AWS
# Secrets Manager — pull it into .env.ingestion.local (gitignored, auto-loaded by
# the backend + ingestion-cron containers):
#   ./scripts/dev-ingestion-secrets.sh pull
# See backend/README.md ("Local ingestion credentials") for the full workflow.
#
# Or set them here directly for a one-off:
# GITHUB_APP_ID=
# Paste the PEM with literal \n escapes, or a real multi-line value.
# GITHUB_APP_PRIVATE_KEY=
# GITHUB_APP_WEBHOOK_SECRET=
# GITHUB_APP_SLUG=

# Fernet key for encrypting future OAuth tool tokens (GitHub App installs do not
# use this — they mint tokens per run).
# TOKEN_ENCRYPTION_KEY=

# First-run backfill window (days) for repo resources; Copilot is capped by GitHub.
# INGESTION_BACKFILL_DAYS=90

# -----------------------------------------------------------------------------
# Integrations (optional — legacy single-token extractors)
# -----------------------------------------------------------------------------

# Linear
# LINEAR_API_KEY=

# Cursor
# CURSOR_API_KEY=

# -----------------------------------------------------------------------------
# AWS deployment (Terraform + GitHub Actions)
# -----------------------------------------------------------------------------
# These values are NOT read from this file in AWS. App config is generic: every
# GitHub Actions variable is forwarded by CI into both the API container env
# (Terraform app_environment) and the SPA build env. Adding a key is just adding
# an Actions variable -- no code changes. Examples:
#   - POSTHOG_TOKEN / POSTHOG_HOST -> API (OTEL -> PostHog) + SPA build
#   - VITE_API_URL                   -> SPA build (set per environment)
# Truly sensitive values use Terraform app_secrets (Secrets Manager) instead.
# See infrastructure/terraform/README.md for the full deploy runbook.
